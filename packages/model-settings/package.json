    "test:watch": "vitest"
  },
  "dependencies": {
    "@counsel/db": "workspace:*",
    "@teamsuzie/agent-loop": "link:../../../agents/packages/agent-loop",
    "kysely": "^0.27.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.13.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
