{
  "name": "@counsel/model-settings",
  "version": "0.1.0",
  "private": true,
  "description": "Per-user model overrides + BYOK provider keys — Postgres-backed via Kysely.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
