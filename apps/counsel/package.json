    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "kysely": "^0.27.4",
    "multer": "^2.0.1",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.2",
