    "@teamsuzie/db-sqlite": "link:../../../agents/packages/db-sqlite",
    "@teamsuzie/docx": "link:../../../agents/packages/docx",
    "@teamsuzie/docx-diff": "link:../../../agents/packages/docx-diff",
    "@teamsuzie/document-versions": "link:../../../agents/packages/document-versions",
    "@teamsuzie/kb": "link:../../../agents/packages/kb",
    "@teamsuzie/markdown-document": "link:../../../agents/packages/markdown-document",
    "@teamsuzie/model-settings": "link:../../../agents/packages/model-settings",
    "@teamsuzie/personas": "link:../../../agents/packages/personas",
    "@teamsuzie/sharing": "link:../../../agents/packages/sharing",
    "@teamsuzie/chats": "link:../../../agents/packages/chats",
    "@teamsuzie/grid-review": "link:../../../agents/packages/grid-review",
