{
  "name": "@counsel/assistant",
  "version": "0.1.0",
  "description": "Suzie Law chat assistant — Express + React on Team Suzie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts & pnpm --filter @counsel/assistant-client dev & wait",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@counsel/db": "workspace:*",
    "@counsel/kb": "workspace:*",
    "@counsel/workspaces": "workspace:*",
    "@counsel/chats": "workspace:*",
    "@counsel/document-versions": "workspace:*",
    "@counsel/model-settings": "workspace:*",
    "@counsel/sharing": "workspace:*",
    "@counsel/personas": "workspace:*",
    "@counsel/grid-review": "workspace:*",
    "@counsel/workflows": "workspace:*",
    "@teamsuzie/agent-loop": "link:../../../agents/packages/agent-loop",
    "@teamsuzie/approvals": "link:../../../agents/packages/approvals",
    "@teamsuzie/citations": "link:../../../agents/packages/citations",
    "@teamsuzie/db-sqlite": "link:../../../agents/packages/db-sqlite",
    "@teamsuzie/docx": "link:../../../agents/packages/docx",
    "@teamsuzie/docx-diff": "link:../../../agents/packages/docx-diff",
    "@teamsuzie/grid-review": "link:../../../agents/packages/grid-review",
    "@teamsuzie/hosted-demo": "link:../../../agents/packages/hosted-demo",
